# LLM Provider: openai | gemini | claude
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

OPENAI_API_KEY=<openai_api_key_here>
GOOGLE_API_KEY=<google_api_key_here>
ANTHROPIC_API_KEY=<anthropic_api_key_here>

# Characters of issue body passed to LLM
# Classify uses the smaller limit, summarize uses the larger
BODY_TRUNCATION_CLASSIFY=500
BODY_TRUNCATION_SUMMARIZE=2000
